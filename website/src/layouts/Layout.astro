---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Flash and configure ExpressLRS receivers and transmitters directly from your iOS or Android device. 100% offline flashing, no PC or cables required." } = Astro.props;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "ELRS Mobile",
  "operatingSystem": "Android, iOS",
  "applicationCategory": "UtilitiesApplication",
  "description": description,
  "offers": {
	"@type": "Offer",
	"price": "0",
	"priceCurrency": "USD"
  }
});
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Structured Data: SoftwareApplication for SEO -->
		<script type="application/ld+json" set:html={schema} />

		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-8X6YE82V0S"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());

			gtag('config', 'G-8X6YE82V0S');
		</script>
	</head>
	<body class="m-0 flex flex-col min-h-screen bg-background text-white font-sans antialiased scroll-smooth">
		<nav class="fixed top-0 inset-x-0 h-16 bg-background/80 backdrop-blur-xl border-b border-white/10 z-[1000] flex items-center">
			<div class="w-full max-w-4xl mx-auto px-4 flex justify-between items-center">
				<a href="/" class="flex items-center gap-3 no-underline text-white font-bold text-lg">
					<img src="/images/logo.svg" alt="Logo" class="w-8 h-8" />
					<span>ELRS Mobile</span>
				</a>
				<div class="flex items-center gap-4 md:gap-6">
					<a href="/supported_hardware" class="hidden md:block no-underline text-text-muted text-sm transition-colors hover:text-primary">Hardware</a>
					<a href="/user_guide" class="hidden md:block no-underline text-text-muted text-sm transition-colors hover:text-primary">Documentation</a>
					<a href="/#installation" class="bg-primary text-background px-4 py-2 rounded-lg no-underline font-bold text-xs md:text-sm transition-transform hover:scale-105">Get App</a>
				</div>
			</div>
		</nav>
		<slot />
	</body>
</html>

<style is:global>
	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}
</style>
